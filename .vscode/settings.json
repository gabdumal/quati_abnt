{
  "[typst]": {
    "editor.defaultFormatter": "myriad-dreamin.tinymist"
  },
  "chat.tools.terminal.autoApprove": {
    "/^python3 /workspace/scripts/gen_prose_csl\\.py$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^python3 scripts/gen_prose_csl\\.py$/": {
      "approve": true,
      "matchCommandLine": true
    }
  },
  "cSpell.words": [
    "abnt",
    "abntex",
    "abnTeX2",
    "tamandua",
    "alice",
    "biblatex",
    "dumont",
    "gabriel",
    "glossarium",
    "hayagriva",
    "Ismália",
    "malosto",
    "oklch",
    "pagebreak",
    "parbreak",
    "postgresql",
    "Termes",
    "typst"
  ],
  "github.copilot.nextEditSuggestions.enabled": true,
  "json.schemaDownload.trustedDomains": {
    "https://raw.githubusercontent.com/DavidAnson/markdownlint/v0.40.0/schema/markdownlint-config-schema.json": true
  },
  "latex-workshop.bibtex-fields.sort.enabled": true,
  "latex-workshop.bibtex-format.sort.enabled": false,
  "latex-workshop.bibtex-format.trailingComma": true,
  "tinymist.formatterMode": "typstyle",
  "tinymist.outputPath": "$root/build/$name",
  "tinymist.projectResolution": "lockDatabase"
}
